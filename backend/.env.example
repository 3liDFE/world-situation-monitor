# World Situation Monitor - Backend Environment Variables
# Copy this file to .env and fill in your API keys

# Server
HOST=0.0.0.0
PORT=8000

# API Keys (optional - app works without them but with reduced functionality)
NEWSDATA_API_KEY=
ANTHROPIC_API_KEY=

# AIS Vessel Tracking (optional - uses simulation fallback without it)
# Register at https://www.aishub.net/ for a free username
AISHUB_USERNAME=

# Database (SQLite path)
DATABASE_URL=sqlite:///./wsm.db
